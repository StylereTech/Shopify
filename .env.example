# Shopify / Style.re delivery app environment template
# Copy to local .env or configure in Railway/Shopify deployment secrets.
# Never commit real credentials.

NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Shopify app credentials from Shopify Partner dashboard
SHOPIFY_API_KEY=<shopify-app-api-key>
SHOPIFY_API_SECRET=<shopify-app-api-secret>
SHOPIFY_SCOPES=write_shipping,read_orders,read_locations

# OAuth/session token security
TOKEN_ENCRYPTION_KEY_HEX=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Persistence / queues
DATABASE_URL=postgres://postgres:postgres@localhost:5432/storree_shopify
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_KEY=storree:dispatch:queue
REDIS_DEAD_LETTER_KEY=storree:dispatch:dlq
WORKER_MAX_RETRIES=3

# DoorDash Drive dispatch
DISPATCH_PROVIDER=doordash
DOORDASH_DEVELOPER_ID=<doordash-developer-id>
DOORDASH_KEY_ID=<doordash-key-id>
DOORDASH_SIGNING_SECRET=<doordash-signing-secret>
DOORDASH_BASE_URL=https://openapi.doordash.com

# Pickup defaults / geocoding
DEFAULT_PICKUP_ADDRESS=<merchant-pickup-address>
DEFAULT_PICKUP_PHONE=+10000000000
DEFAULT_PICKUP_NAME=<merchant-or-store-name>
GOOGLE_MAPS_API_KEY=<google-maps-api-key>

# Stripe merchant billing / order payment
STRIPE_SECRET_KEY=sk_test_<placeholder>
STRIPE_WEBHOOK_SECRET=whsec_<placeholder>
MERCHANT_STRIPE_PRICE_ACCESS=price_<placeholder>
MERCHANT_STRIPE_PRICE_GROWTH=price_<placeholder>
MERCHANT_JWT_SECRET=<generate-strong-secret>

# SMS/admin alerts
ADMIN_PHONE_NUMBER=+10000000000
TWILIO_ACCOUNT_SID=AC<placeholder>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_FROM_NUMBER=+10000000000

# Legacy isolated-test placeholders only, not production dispatch
STORREE_API_BASE_URL=https://storree-placeholder.invalid
STORREE_API_KEY=placeholder
STORREE_TIMEOUT_MS=5000
STORREE_MAX_RETRIES=2
