{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build && cp -r src/infrastructure/db/migrations dist/infrastructure/db/migrations"
  },
  "deploy": {
    "startCommand": "node dist/infrastructure/db/migrate.js && node dist/server.js",
    "healthcheckPath": "/health/ready",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
